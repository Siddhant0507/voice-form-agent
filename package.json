{
  "name": "voice-form-agent",
  "version": "0.1.5",
  "description": "Convert any form into a voice conversation powered by Vapi AI",
  "keywords": ["vapi", "voice", "form", "react", "ai", "voice-form"],
  "author": "",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17",
    "@vapi-ai/web": ">=2.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "@vapi-ai/web": "^2.5.2"
  },
  "overrides": {
    "@daily-co/daily-js": "0.90.0"
  }
}
